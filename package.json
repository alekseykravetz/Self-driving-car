{
  "name": "self-driving-car",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run tsc:watch\" \"npm run serve\" \"npm run fix:all\"",
    "serve": "serve -p 9090",
    "tsc:watch": "tsc --watch",
    "watch:fix": "onchange -i \"ts/**/*.ts\" \"html/**/*.html\" \"styles/**/*.css\" -- npm run fix:all",
    "fix:all": "npm run format && npm run lint",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "lint:log": "eslint",
    "lint:watch": "node --watch --watch-path=ts node_modules/eslint/bin/eslint.js ts/**/*.ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "globals": "^16.0.0",
    "onchange": "^7.1.0",
    "prettier": "3.5.3",
    "serve": "^14.2.4",
    "typescript": "^5.8.2"
  }
}
