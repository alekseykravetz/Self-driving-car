{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "planner",
  "instructions": ["AGENTS.md"],
  "snapshot": true,
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "build": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {}
    }
  },
  "plugin": [".opencode/plugins/graphify.js"],
  "permission": {
    "bash": "allow"
  },
  "command": {
    "test": {
      "description": "Run all vitest unit tests",
      "agent": "build"
    },
    "fix": {
      "description": "Format + lint fix the entire codebase",
      "agent": "build"
    },
    "start": {
      "description": "Start dev server (tsc watch + serve + lint/format watcher)",
      "agent": "build"
    }
  }
}
