{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "planner",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "agent": {
    "build": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "env": {}
    }
  },
  "plugin": [".opencode/plugins/graphify.js"],
  "permission": {
    "bash": "allow"
  }
}
